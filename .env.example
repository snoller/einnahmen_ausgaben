# App-Zugang (ein Passwort für die ganze Installation)
APP_PASSWORD=dein-sicheres-passwort

# Zufälliger String für Session-Cookies (min. 32 Zeichen)
SESSION_SECRET=bitte-einen-langen-zufaelligen-string-hier

# Google AI Studio API Key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
# Optional schnelleres Modell nur für Sprache (z.B. gemini-3.1-flash-lite-preview)
# GEMINI_AUDIO_MODEL=gemini-3.1-flash-lite-preview

PORT=3847
